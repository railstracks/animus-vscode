{
  "name": "animus-ide",
  "displayName": "Animus IDE",
  "description": "Persistent AI agents in your IDE — powered by Animus",
  "version": "0.0.2",
  "publisher": "artificers",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/railstracks/animus-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Chat", "Other"],
  "keywords": ["ai", "agent", "llm", "assistant", "animus"],
  "icon": "media/icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:animus-sessions"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "animus",
          "title": "Animus",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "animus": [
        {
          "type": "webview",
          "id": "animus-sessions",
          "name": "Animus"
        }
      ]
    },
    "commands": [
      {
        "command": "animus.connect",
        "title": "Animus: Connect",
        "icon": "$(plug)"
      },
      {
        "command": "animus.disconnect",
        "title": "Animus: Disconnect",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "animus.configureConnection",
        "title": "Animus: Configure Connection",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": []
    },
    "configuration": {
      "title": "Animus",
      "properties": {
        "animus.daemonUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "URL of the Animus daemon"
        },
        "animus.authToken": {
          "type": "string",
          "default": "",
          "description": "Admin auth token for the Animus daemon",
          "scope": "machine"
        },
        "animus.agentId": {
          "type": "string",
          "default": "",
          "description": "Default agent ID to use for new sessions"
        },
        "animus.node": {
          "type": "string",
          "default": "",
          "description": "Node name for workspace tool routing (e.g. 'workstation')"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^3.0.0"
  }
}
